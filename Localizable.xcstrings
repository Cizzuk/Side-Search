    },
    "You can launch the Side Search assistant using the Shortcuts." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ショートカットを使ってSide Searchのアシスタントを起動することができます。"
