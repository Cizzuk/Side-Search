          "stringUnit" : {
            "state" : "translated",
            "value" : "アシスタントを待っています…"
          }
        }
      }
    },
    "With a compatible assistant, you can continue conversations in the background even if you close Side Search during speech recognition." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "対応するアシスタントでは、音声認識中にアプリを閉じてもバックグラウンドで会話を続けることができます。"
          }
        }
      }
